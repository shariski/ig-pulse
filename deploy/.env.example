# IG Pulse — VPS environment. Copy to /opt/ig-pulse/.env and fill in.
# This file holds SECRETS; the real .env is never committed.

# --- Meta / Instagram Graph API app (the shared "Pulse" Meta app) ---
# Each user connects their own IG account in-app; this is just the app identity
# used to exchange tokens.
FB_APP_ID=
FB_APP_SECRET=

# --- Session signing key ---
# Generate once and keep stable (rotating it logs everyone out):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# --- Registration gate (optional) ---
# Leave UNSET for open registration (anyone can sign up). To restrict sign-ups,
# set a shared code that new users must enter:
# REGISTER_CODE=

# NOTE: data paths (REGISTRY_PATH, DATA_DIR, HF_HOME, DATABASE_PATH) are set in
# docker-compose.prod.yml so all state lands in the ig-pulse-data volume — no
# need to set them here.
