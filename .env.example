# Meta / Instagram (Instagram API with Instagram Login)
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here
# Optional — only if the Instagram app secret differs from FB_APP_SECRET
# (find it in the Instagram Login use-case settings). Used for long-lived exchange.
# IG_APP_SECRET=your_instagram_app_secret_here
IG_USER_ID=your_ig_user_id_here
IG_ACCESS_TOKEN=your_long_lived_token_here

# App config
DATABASE_PATH=./ig_pulse.db
LOG_LEVEL=INFO
TIMEZONE=Asia/Jakarta
